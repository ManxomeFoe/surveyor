<?xml version="1.0" encoding="utf-8"?>
<!-- Fidalgo: minimalist morion helmet with a pencil across it -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group android:translateY="12">
    <!-- comb: solid crescent fin, baseline buried in the dome -->
    <path
        android:fillColor="#EDE7DA"
        android:pathData="M44,40 C44,28 48.5,21.5 54,21.5 C59.5,21.5 64,28 64,40 Z"/>
    <!-- dome -->
    <path
        android:fillColor="#EDE7DA"
        android:pathData="M36,52 C36,39.5 44,32 54,32 C64,32 72,39.5 72,52 Z"/>
