        android:strokeColor="#16305C"
        android:strokeWidth="1.5"
        android:pathData="M40,36 C44,33.3 49,32 54,32 C59,32 64,33.3 68,36"/>
    <!-- brim: upswept, pointed tips -->
    <path
        android:fillColor="#EDE7DA"
        android:pathData="M24.5,42.5 C29,52.5 40,56.5 54,56.5 C68,56.5 79,52.5 83.5,42.5 C84.1,41.2 85.6,41.7 85.2,43 C81.5,56 68,61.5 54,61.5 C40,61.5 26.5,56 22.8,43 C22.4,41.7 23.9,41.2 24.5,42.5 Z"/>
